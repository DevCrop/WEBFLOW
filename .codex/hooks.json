{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^mcp__webflow",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File .codex/hooks/webflow_doc_sync.ps1",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -File .codex\\hooks\\webflow_doc_sync.ps1",
            "timeout": 10,
            "statusMessage": "Checking Webflow documentation sync"
          }
        ]
      }
    ]
  }
}
